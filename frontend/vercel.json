{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/((?!faq\\.html|admin\\.html|sitemap\\.xml|robots\\.txt|google.*\\.html|icon.*|logo\\.svg|manifest\\.json|sw\\.js).*)", "destination": "/index.html" }
  ]
}
